; -----------------------------------------------------------------------------
; Collisions & Event Management
; -----------------------------------------------------------------------------
CHK_COLL:
    LDA COLL_REG    
    STA TMP_COLL
    JSR CHK_BOSS_COLL

CHK_R1:
    LDA EXP_ACT
    BNE CHK_R2
    LDA TMP_COLL
    AND #$06        
    CMP #$06
    BNE CHK_R2
    
    LDA SBEAM_ACT
    BNE SKP_LSR_DEL1
    LDA #$00
    STA LSR_ACT
    STA S1_Y
SKP_LSR_DEL1:
    LDA #$01
    STA EXP_ACT
    JSR SND_EXPL
    LDA #$18
    STA EXP_TIM
    LDA #EXP_BLK
    STA S2_PTR
    JSR ADD_SCORE

CHK_R2:
    LDA EXP2_ACT
    BNE CHK_P1
    LDA TMP_COLL
    AND #$0A        
    CMP #$0A
    BNE CHK_P1
    
    LDA SBEAM_ACT
    BNE SKP_LSR_DEL2
    LDA #$00
    STA LSR_ACT
    STA S1_Y
SKP_LSR_DEL2:
    LDA #$01
    STA EXP2_ACT
    JSR SND_EXPL
    LDA #$18
    STA EXP2_TIM
    LDA #EXP_BLK
    STA S3_PTR
    JSR ADD_SCORE

CHK_P1:
    LDA TMP_COLL
    AND #$11        
    CMP #$11
    BNE CHK_E_LSR
    
    JSR SND_PWR
    LDA PWR_TYP
    BEQ CHK_P1_HEART 
    CMP #$01
    BEQ CHK_P1_FISH  
    CMP #$02
    BEQ CHK_P1_NIP   
    CMP #$03
    BEQ CHK_P1_YARN
    CMP #$04
    BEQ CHK_P1_SUPER
    JMP CLEANUP_PWR

CHK_P1_YARN:         
    JSR ADD_1000     
    JMP CLEANUP_PWR

CHK_P1_FISH:
    JSR ADD_200      
    JMP CLEANUP_PWR

CHK_P1_NIP:
    JSR ADD_500      
    JMP CLEANUP_PWR

CHK_P1_HEART:
    LDA LIVES
    CMP #$09        
    BEQ CLEANUP_PWR
    INC LIVES        

CHK_P1_SUPER:
    LDA #$01
    STA SBEAM_ACT        
    LDA #$08         
    STA SBEAM_TIM_L      
    LDA #$07
    STA SBEAM_TIM_H      
    JSR ADD_500
    JMP CLEANUP_PWR

CLEANUP_PWR:
    LDA #$40
    STA PWR_ACT      
    LDA #$00
    STA S4_Y
    JSR DRW_SCR      

CHK_E_LSR:
    LDA TMP_COLL
    AND #$41       
    CMP #$41
    BEQ PL_HIT

PL_COLL_CHK:
    LDA HIT_TIM
    BNE EXT_COLL         
    
    LDA TMP_COLL
    AND #$05
    CMP #$05
    BEQ PL_HIT
    
    LDA TMP_COLL
    AND #$09
    CMP #$09
    BEQ PL_HIT

    LDA BOSS_ACT
    CMP #$01
    BNE EXT_COLL         
    LDA TMP_COLL
    AND #$21
    CMP #$21
    BNE EXT_COLL

PL_HIT:
    JSR PROCESS_DAMAGE

EXT_COLL:
    RTS

CHK_BOSS_COLL:
    LDA BOSS_ACT
    CMP #$01
    BNE NO_B_HIT
    LDA TMP_COLL
    AND #$22       
    CMP #$22
    BNE NO_B_HIT
    
    LDA #$00
    STA LSR_ACT    
    STA S1_Y
    
    DEC BOSS_HP
    BEQ BOSS_DEAD
    JSR SND_EXPL
    RTS
BOSS_DEAD:
    JMP KILL_BOSS
NO_B_HIT:
    RTS

PROCESS_DAMAGE:
    DEC LIVES
    BEQ PL_DEAD
    LDA #$40             
    STA HIT_TIM
    JSR SND_EXPL        
    JSR DRW_SCR        
    RTS

PL_DEAD:
    JMP DO_GAME_OVER

KILL_BOSS:
    LDA #$03        
    STA BOSS_ACT
    LDA #$20        
    STA BOSS_EXP_TIM
    LDA #EXP_BLK    
    STA S5_PTR
    JSR SND_EXPL
    JSR ADD_1000
    
    INC LEVEL
    LDA LEVEL
    CMP #$09        
    BNE NO_WIN
    JMP VICTORY_SCREEN
NO_WIN:
    JSR DRW_SCR      
    RTS

